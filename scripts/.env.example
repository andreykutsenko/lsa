# LSA workflow scripts — environment configuration
#
# PRIMARY config: ~/.lsa/config.yaml (created by ./scripts/setup.sh)
# These env vars are a FALLBACK and override config.yaml values.
#
# Copy the relevant lines to ~/.bashrc (or ~/.zshrc) if you prefer
# env vars over the YAML config.

# Root directory where RHS snapshots are stored
# export SNAPROOT="$HOME/snapshots"

# Root directory where per-ticket workspaces are created
# export WORKROOT="$HOME/workspaces"

# SSH host for the RHS server
# export RHS_HOST="linux-server.company.com"

# SSH username (optional, defaults to current user)
# export RHS_USER="jsmith"
