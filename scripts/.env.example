# LSA workflow scripts — environment configuration
#
# Copy the relevant lines to ~/.bashrc (or ~/.zshrc) and adjust paths.
# These env vars override the hardcoded defaults in mk_snap_and_scan.sh
# and mk_ticket_ws.sh.

# Root directory where RHS snapshots are stored
export SNAPROOT="/path/to/your/rhs_snapshot_project"

# Root directory where per-ticket workspaces are created
export WORKROOT="/path/to/your/ticket_workspaces"

# SSH alias/host for the RHS server (must be configured in ~/.ssh/config)
export RHS_HOST="rhs"
